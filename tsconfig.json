{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "next": [
        "./src/mocks/next-link.tsx"
      ],
      "next/image": [
        "./src/mocks/next-image.tsx"
      ],
      "next/font/google": [
        "./src/mocks/next-font-google.tsx"
      ],
      "next/dynamic": [
        "./src/mocks/next-dynamic.tsx"
      ],
      "next/link": [
        "./src/mocks/next-link.tsx"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  }
}
